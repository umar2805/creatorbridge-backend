# ── Google OAuth credentials ──
# Get these from Google Cloud Console > APIs & Services > Credentials
# Create an "OAuth 2.0 Client ID" of type "Web application"
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# This MUST exactly match one of the "Authorized redirect URIs" you register
# in Google Cloud Console for this client.
#
# Examples:
#   Local dev:    http://127.0.0.1:8787/auth/google/callback
#   Production:   https://your-backend-host.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/auth/google/callback

# ── Session / JWT ──
# Use a long random string in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Frontend ──
# Where the browser should be sent after a successful/failed login.
# This is whatever origin serves your index.html.
#
# Examples:
#   Local dev:    http://127.0.0.1:5500
#   Production:   https://umar2805.github.io/PROJECT-SHUTDOWN-3
FRONTEND_URL=http://127.0.0.1:5500

# Comma-separated list of additional origins allowed to call this API
# (for CORS). FRONTEND_URL is always allowed automatically.
EXTRA_ALLOWED_ORIGINS=

# ── Server ──
PORT=8787

# Set to "production" when deploying behind HTTPS so cookies are
# marked Secure and SameSite=None (required for cross-site cookies
# between GitHub Pages and a separate backend host).
NODE_ENV=development
